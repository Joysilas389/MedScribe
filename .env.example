# ===================================
# MedScribe Environment Configuration
# ===================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets to source control.

# --- Application ---
APP_NAME=MedScribe
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Security ---
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256
BCRYPT_ROUNDS=12

# --- Database ---
DATABASE_URL=sqlite:///./medscribe.db
# For production: DATABASE_URL=postgresql://user:password@host:5432/medscribe

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# --- Audio / Transcription ---
# Whisper API or compatible endpoint
TRANSCRIPTION_API_URL=https://api.openai.com/v1/audio/transcriptions
TRANSCRIPTION_API_KEY=CHANGE_ME
TRANSCRIPTION_MODEL=whisper-1

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_MINUTES=15

# --- Data Retention ---
DATA_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=2555

# --- Frontend (set in frontend/.env) ---
# VITE_API_BASE_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
